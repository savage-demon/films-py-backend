APP_TITLE="Films API"
APP_VERSION="0.0.1"
DEBUG=False

DB_URL=mysql+asyncmy://user:pass@dburl:3306/sakila
# Укажите имя базы в MONGO_URL: оно берется из path-части URL.
# Без имени базы, например mongodb://mongo:27017, приложение не сможет выбрать default database.
MONGO_URL=mongodb://mongo:27017/films_py
POPULAR_SEARCHES_STORE_LIMIT=20
POPULAR_SEARCHES_DEFAULT_LIMIT=5
